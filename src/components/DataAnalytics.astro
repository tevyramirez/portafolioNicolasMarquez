---
// Componente DataAnalytics.astro - Sección 3: Data Analytics & Interactive Simulator
---

<section id="analisis-datos" class="py-16 md:py-24 border-b border-dmk-muted/20 relative">
  <div class="space-y-12">
    
    <!-- Encabezado de la Sección -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6 items-end">
      <div class="md:col-span-8 space-y-4">
        <div class="font-mono text-xs text-dmk-accent uppercase tracking-wider flex items-center gap-2">
          <span class="text-dmk-muted">03 /</span> DATA ANALYTICS & INTERACTIVE SOLUTIONS
        </div>
        <h2 class="font-serif text-3xl sm:text-4xl md:text-5xl font-semibold text-dmk-text tracking-tight">
          Soluciones de Analítica de Datos Avanzada
        </h2>
      </div>
      <div class="md:col-span-4">
        <p class="font-mono text-[11px] text-dmk-muted border-l-2 border-dmk-accent pl-4 leading-relaxed">
          Modelado predictivo, machine learning y herramientas matemáticas diseñadas para gobernar la incertidumbre de los negocios.
        </p>
      </div>
    </div>

    <!-- Bloque de Contenido Teórico-Técnico -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      
      <!-- Textos Descriptivos de Servicios Técnicos (5 cols) -->
      <div class="lg:col-span-5 space-y-6">
        <div class="space-y-2">
          <span class="font-mono text-[10px] text-dmk-accent uppercase tracking-widest block">People Analytics Aplicado</span>
          <h3 class="font-serif text-xl sm:text-2xl font-bold text-dmk-text">
            El Modelo Circumplejo de Emociones
          </h3>
          <p class="font-sans text-xs sm:text-sm text-dmk-muted leading-relaxed">
            La efectividad de un equipo no se define solo por sus habilidades de software, sino por el tono emocional colectivo. Implementamos el modelo circumplejo (Russell), cruzando la <strong>valencia</strong> (afecto agradable vs. desagradable) con la <strong>activación</strong> (estado de alerta activo vs. pasivo), para diagnosticar de forma precisa y estadística el rendimiento de tus equipos bajo estrés corporativo.
          </p>
        </div>

        <div class="space-y-2 border-t border-dmk-muted/10 pt-4">
          <span class="font-mono text-[10px] text-dmk-accent uppercase tracking-widest block">Modelamiento Heurístico y ML</span>
          <h3 class="font-serif text-xl sm:text-2xl font-bold text-dmk-text">
            Pronóstico de Éxito en Nuevos Proyectos
          </h3>
          <p class="font-sans text-xs sm:text-sm text-dmk-muted leading-relaxed">
            Utilizamos algoritmos personalizados de machine learning entrenados para evaluar el nivel de madurez organizacional y predecir el éxito en proyectos de corporate venturing, reduciendo la probabilidad de falla mediante simulaciones Monte Carlo previas al despliegue de capital.
          </p>
        </div>

        <div class="space-y-2 border-t border-dmk-muted/10 pt-4">
          <span class="font-mono text-[10px] text-dmk-accent uppercase tracking-widest block">Dashboard de Negocio</span>
          <h3 class="font-serif text-xl sm:text-2xl font-bold text-dmk-text">
            Cuadros de Mando Interactivos (BI)
          </h3>
          <p class="font-sans text-xs sm:text-sm text-dmk-muted leading-relaxed">
            Integración de tableros de control directamente en tus sistemas para monitorear en tiempo real variables financieras, conductuales e indicadores clave de innovación en toda la geografía regional.
          </p>
        </div>
      </div>

      <!-- Simulador de People Analytics (7 cols) - Enfoque "Cute-alism" / MIT Media Lab Magic -->
      <div class="lg:col-span-7 border border-dmk-muted/20 bg-dmk-bg p-6 sm:p-8 rounded-sm relative overflow-hidden group shadow-2xl">
        
        <!-- Línea Cyber Green decorativa superior -->
        <div class="absolute top-0 left-0 w-full h-[2px] bg-dmk-accent/60"></div>

        <div class="flex items-center justify-between border-b border-dmk-muted/10 pb-4 mb-6 font-mono text-[10px] text-dmk-muted/70">
          <span>SIMULATOR: PEOPLE_ANALYTICS_CIRCUMPLEX_v2</span>
          <span class="text-dmk-accent">INTERACTIVE LAB // ESTÁTICO</span>
        </div>

        <div class="space-y-8">
          
          <!-- Controles de Ajuste (Sliders) -->
          <div class="space-y-6">
            <h4 class="font-serif text-base font-bold text-dmk-text flex items-center gap-2">
              <span class="h-1.5 w-1.5 rounded-full bg-dmk-accent"></span>
              Parámetros de Entrada de Clima de Equipo
            </h4>

            <!-- Slider 1: Valencia -->
            <div class="space-y-2">
              <div class="flex justify-between text-xs font-mono">
                <span class="text-dmk-text/90">Valencia Afectiva (Eje X)</span>
                <span class="text-dmk-accent font-bold" id="val-display">5.0 / 10.0</span>
              </div>
              <input 
                type="range" 
                min="0" 
                max="10" 
                step="0.1" 
                value="5.0" 
                id="val-slider" 
                class="w-full h-1 bg-dmk-card rounded-lg appearance-none cursor-pointer accent-dmk-accent outline-none border border-dmk-muted/10"
              />
              <div class="flex justify-between text-[9px] font-mono text-dmk-muted/50">
                <span>Desagradable / Estrés</span>
                <span>Neutro</span>
                <span>Agradable / Placentero</span>
              </div>
            </div>

            <!-- Slider 2: Activación -->
            <div class="space-y-2">
              <div class="flex justify-between text-xs font-mono">
                <span class="text-dmk-text/90">Activación Afectiva (Eje Y)</span>
                <span class="text-dmk-accent font-bold" id="act-display">5.0 / 10.0</span>
              </div>
              <input 
                type="range" 
                min="0" 
                max="10" 
                step="0.1" 
                value="5.0" 
                id="act-slider" 
                class="w-full h-1 bg-dmk-card rounded-lg appearance-none cursor-pointer accent-dmk-accent outline-none border border-dmk-muted/10"
              />
              <div class="flex justify-between text-[9px] font-mono text-dmk-muted/50">
                <span>Pasivo / Apatía</span>
                <span>Neutro</span>
                <span>Activo / Alerta</span>
              </div>
            </div>
          </div>

          <!-- Resultados y Métricas Predictivas Recalculadas -->
          <div class="border-t border-dmk-muted/10 pt-6 space-y-6">
            <h4 class="font-serif text-base font-bold text-dmk-text flex items-center gap-2">
              <span class="h-1.5 w-1.5 rounded-full bg-dmk-accent"></span>
              Resultados Predictivos Computados (ML Engine)
            </h4>

            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
              
              <!-- Métrica 1: Cuadrante Circumplex -->
              <div class="border border-dmk-muted/10 bg-dmk-card/30 p-4 rounded-sm flex flex-col justify-between">
                <span class="font-mono text-[9px] uppercase tracking-wider text-dmk-muted/60 block mb-1">Cuadrante Russell</span>
                <div class="font-serif text-base font-bold text-dmk-text leading-tight" id="quad-display">
                  Neutro / Balance
                </div>
                <div class="text-[9px] font-mono text-dmk-muted mt-3" id="quad-desc">
                  Clima equilibrado con dinámica estándar.
                </div>
              </div>

              <!-- Métrica 2: Tasa de Innovación -->
              <div class="border border-dmk-muted/10 bg-dmk-card/30 p-4 rounded-sm flex flex-col justify-between">
                <span class="font-mono text-[9px] uppercase tracking-wider text-dmk-muted/60 block mb-1">Efectividad de Innovación</span>
                <div class="font-mono text-xl sm:text-2xl font-bold text-dmk-text" id="innov-display">
                  50.0%
                </div>
                <div class="h-1 w-full bg-dmk-card rounded-full overflow-hidden mt-3 border border-dmk-muted/10">
                  <div class="h-full bg-dmk-accent transition-all duration-300" style="width: 50%" id="innov-bar"></div>
                </div>
              </div>

              <!-- Métrica 3: Rotación voluntaria -->
              <div class="border border-dmk-muted/10 bg-dmk-card/30 p-4 rounded-sm flex flex-col justify-between">
                <span class="font-mono text-[9px] uppercase tracking-wider text-dmk-muted/60 block mb-1">Riesgo de Deserción (Chur)</span>
                <div class="font-mono text-xl sm:text-2xl font-bold text-dmk-text" id="turnover-display">
                  15.0%
                </div>
                <div class="h-1 w-full bg-dmk-card rounded-full overflow-hidden mt-3 border border-dmk-muted/10">
                  <div class="h-full bg-dmk-accent transition-all duration-300" style="width: 15%" id="turnover-bar"></div>
                </div>
              </div>

            </div>

            <!-- Gráfico de Dispersión Dinámico Simplificado -->
            <div class="border border-dmk-muted/15 bg-dmk-bg/80 p-4 rounded-sm flex flex-col items-center">
              <span class="font-mono text-[9px] uppercase tracking-wider text-dmk-accent block mb-4 self-start">Visualización Espacial del Modelo</span>
              
              <!-- Rejilla de Coordenadas Emocionales -->
              <div class="relative w-full max-w-[280px] aspect-square border border-dmk-muted/20">
                <!-- Ejes Centrales -->
                <div class="absolute inset-x-0 top-1/2 -translate-y-1/2 h-[1px] bg-dmk-muted/30 border-dashed"></div>
                <div class="absolute inset-y-0 left-1/2 -translate-x-1/2 w-[1px] bg-dmk-muted/30 border-dashed"></div>
                
                <!-- Etiquetas de los Extremos -->
                <span class="absolute top-1 left-1/2 -translate-x-1/2 font-mono text-[8px] text-dmk-muted/60 uppercase">Activación (Alta)</span>
                <span class="absolute bottom-1 left-1/2 -translate-x-1/2 font-mono text-[8px] text-dmk-muted/60 uppercase">Desactivación</span>
                <span class="absolute left-1 top-1/2 -translate-y-1/2 font-mono text-[8px] text-dmk-muted/60 uppercase rotate-90 origin-left">Valencia (Baja)</span>
                <span class="absolute right-1 top-1/2 -translate-y-1/2 font-mono text-[8px] text-dmk-muted/60 uppercase -rotate-90 origin-right">Valencia (Alta)</span>

                <!-- Punto de Coordenadas Móvil -->
                <div 
                  id="plot-dot" 
                  class="absolute h-3 w-3 rounded-full bg-dmk-accent border border-dmk-bg -translate-x-1/2 -translate-y-1/2 shadow-[0_0_10px_rgba(0,255,133,0.8)] transition-all duration-300"
                  style="left: 50%; top: 50%;"
                ></div>
              </div>
            </div>

          </div>

        </div>

      </div>

    </div>

  </div>
</section>

<!-- Script para el recalculador matemático y dinámico en cliente (Islands Magic) -->
<script>
  const valSlider = document.getElementById('val-slider') as HTMLInputElement;
  const actSlider = document.getElementById('act-slider') as HTMLInputElement;

  const valDisplay = document.getElementById('val-display');
  const actDisplay = document.getElementById('act-display');

  const quadDisplay = document.getElementById('quad-display');
  const quadDesc = document.getElementById('quad-desc');

  const innovDisplay = document.getElementById('innov-display');
  const innovBar = document.getElementById('innov-bar');

  const turnoverDisplay = document.getElementById('turnover-display');
  const turnoverBar = document.getElementById('turnover-bar');

  const plotDot = document.getElementById('plot-dot');

  function calculateModels() {
    if (!valSlider || !actSlider) return;

    const val = parseFloat(valSlider.value); // 0 a 10
    const act = parseFloat(actSlider.value); // 0 a 10

    // Actualizar pantallas
    if (valDisplay) valDisplay.textContent = `${val.toFixed(1)} / 10.0`;
    if (actDisplay) actDisplay.textContent = `${act.toFixed(1)} / 10.0`;

    // Actualizar Punto de Gráfico de Dispersión
    if (plotDot) {
      // El rango es 0-10, mapear a 0%-100% de la caja
      // Invertir eje Y para que 10 sea arriba y 0 abajo
      const leftPct = val * 10;
      const topPct = (10 - act) * 10;
      plotDot.style.left = `${leftPct}%`;
      plotDot.style.top = `${topPct}%`;
    }

    // Clasificar Cuadrante Russell y Calcular Variables Predictivas
    let cuadrante = "Neutro / Balance";
    let descripcion = "Dinámica estable con niveles balanceados de energía y afecto.";
    let innovRate = 50;
    let turnoverRate = 15;

    const vDiff = val - 5.0; // Desviación de la mitad
    const aDiff = act - 5.0;

    if (vDiff >= 0.5 && aDiff >= 0.5) {
      cuadrante = "Entusiasmo / Resonancia";
      descripcion = "Clima altamente constructivo. Alta energía orientada a objetivos y seguridad psicológica para experimentar.";
      // ML Formula: Mayor valencia y activación = pico de innovación, bajísima rotación
      innovRate = 50 + (vDiff * 6) + (aDiff * 4);
      turnoverRate = Math.max(3, 15 - (vDiff * 2) - (aDiff * 0.5));
    } else if (vDiff < -0.5 && aDiff >= 0.5) {
      cuadrante = "Tensión / Frustración";
      descripcion = "Alta energía pero con foco negativo. Riesgo de conflicto intergrupal, exigencia excesiva o desalineación estratégica.";
      // ML Formula: Alta energía pero afecto negativo = innovación caótica e inefectiva, riesgo pico de rotación (burnout)
      innovRate = Math.max(15, 50 - (Math.abs(vDiff) * 3) + (aDiff * 2));
      turnoverRate = 15 + (Math.abs(vDiff) * 8) + (aDiff * 3);
    } else if (vDiff < -0.5 && aDiff < -0.5) {
      cuadrante = "Fatiga / Deserción Pasiva";
      descripcion = "Energía y afecto bajos. Clima de apatía estructural y desconexión intelectual. Cero proactividad.";
      // ML Formula: Baja energía y afecto negativo = nula innovación y alta deserción pasiva silenciosa
      innovRate = Math.max(5, 50 - (Math.abs(vDiff) * 5) - (Math.abs(aDiff) * 4));
      turnoverRate = 15 + (Math.abs(vDiff) * 5) - (Math.abs(aDiff) * 1.5);
    } else if (vDiff >= 0.5 && aDiff < -0.5) {
      cuadrante = "Calma / Cooperación Pasiva";
      descripcion = "Clima seguro y agradable, pero con baja tensión creativa. Excelente para operaciones estándar, no para disrupción.";
      // ML Formula: Buen afecto pero baja energía = innovación baja pero estable, bajísima rotación
      innovRate = Math.max(25, 50 + (vDiff * 2) - (Math.abs(aDiff) * 4));
      turnoverRate = Math.max(2, 15 - (vDiff * 2.5) - (Math.abs(aDiff) * 1.5));
    }

    // Truncar cotas
    innovRate = Math.min(100, Math.max(0, innovRate));
    turnoverRate = Math.min(100, Math.max(0, turnoverRate));

    // Renderizar resultados en pantalla
    if (quadDisplay) quadDisplay.textContent = cuadrante;
    if (quadDesc) quadDesc.textContent = descripcion;
    if (innovDisplay) innovDisplay.textContent = `${innovRate.toFixed(1)}%`;
    if (turnoverDisplay) turnoverDisplay.textContent = `${turnoverRate.toFixed(1)}%`;

    // Cambiar barras
    if (innovBar) {
      innovBar.style.width = `${innovRate}%`;
      // Cambiar color basado en rendimiento
      if (innovRate >= 70) {
        innovBar.style.backgroundColor = '#00FF85'; // Cyber Green
      } else if (innovRate >= 40) {
        innovBar.style.backgroundColor = '#A3B0A7'; // Sage Green
      } else {
        innovBar.style.backgroundColor = '#fa5555'; // Red alert
      }
    }

    if (turnoverBar) {
      turnoverBar.style.width = `${turnoverRate}%`;
      if (turnoverRate >= 35) {
        turnoverBar.style.backgroundColor = '#fa5555'; // High risk Red
      } else if (turnoverRate >= 18) {
        turnoverBar.style.backgroundColor = '#A3B0A7'; // Sage Green
      } else {
        turnoverBar.style.backgroundColor = '#00FF85'; // Cyber Green
      }
    }
  }

  // Escuchar eventos de cambio en los sliders
  if (valSlider && actSlider) {
    valSlider.addEventListener('input', calculateModels);
    actSlider.addEventListener('input', calculateModels);
    
    // Ejecución inicial para pintar datos iniciales
    calculateModels();
  }
</script>
