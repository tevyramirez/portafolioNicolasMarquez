---
import { cvData } from '../data/cvData';
---

<section id="docencia" class="border-b border-dmk-border/30">
  <div class="max-w-5xl mx-auto px-8 md:px-12 py-14 md:py-20">
    <h2 class="font-serif text-2xl font-bold mb-8 text-dmk-text reveal stagger-1">Docencia y Servicio Académico</h2>

    <div class="space-y-6">
      {cvData.academicPositions.map((pos, index) => (
        <div class="grid grid-cols-1 md:grid-cols-12 gap-4 reveal stagger-{index + 2} group hover-lift p-4 rounded-sm transition-all duration-300 hover:bg-dmk-card/50">
          <div class="md:col-span-3">
            <div class="font-sans text-sm text-dmk-muted font-medium">{pos.period}</div>
          </div>
          <div class="md:col-span-9 space-y-1">
            <h3 class="font-serif text-base font-semibold text-dmk-text group-hover:text-dmk-accent transition-colors duration-300">{pos.role.es}</h3>
            <p class="font-sans text-sm text-dmk-muted">{pos.institution}</p>
            <ul class="mt-1 space-y-1 font-sans text-sm text-dmk-text">
              {pos.details.es.map((detail) => (
                <li class="flex items-start gap-2">
                  <span class="w-1 h-1 rounded-full bg-dmk-accent mt-2 flex-shrink-0"></span>
                  {detail}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-10 pt-8 border-t border-dmk-border/30 reveal stagger-5">
      <h3 class="font-serif text-lg font-semibold mb-4 text-dmk-text">Áreas de Docencia</h3>
      <div class="flex flex-wrap gap-2">
        {cvData.teachingAreas.map((area, index) => (
          <span class="font-sans text-sm px-3 py-1.5 bg-dmk-card border border-dmk-border/30 text-dmk-text hover:border-dmk-accent/50 hover:bg-dmk-accent/5 transition-all duration-300 cursor-default hover:-translate-y-0.5 reveal stagger-{index + 6}">{area}</span>
        ))}
      </div>
    </div>
  </div>
</section>
