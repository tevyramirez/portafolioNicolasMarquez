---
import { cvData } from '../data/cvData';
---

<section id="experiencia" class="border-b border-dmk-border/30">
  <div class="max-w-5xl mx-auto px-8 md:px-12 py-14 md:py-20">
    <h2 class="font-serif text-2xl font-bold mb-8 text-dmk-text reveal stagger-1">Experiencia Profesional</h2>

    <div class="space-y-6">
      {cvData.professionalExperience.map((exp, index) => (
        <div class="grid grid-cols-1 md:grid-cols-12 gap-4 reveal stagger-{index + 2} group hover-lift p-4 rounded-sm transition-all duration-300 hover:bg-dmk-card/50">
          <div class="md:col-span-3">
            <div class="font-sans text-sm text-dmk-muted font-medium">{exp.period}</div>
          </div>
          <div class="md:col-span-9 space-y-1">
            <h3 class="font-serif text-base font-semibold text-dmk-text group-hover:text-dmk-accent transition-colors duration-300">{exp.position}</h3>
            <p class="font-sans text-sm text-dmk-muted">{exp.organization}</p>
            <ul class="mt-1 space-y-1 font-sans text-sm leading-relaxed text-dmk-text">
              {exp.details.map((detail) => (
                <li class="flex items-start gap-2">
                  <span class="w-1 h-1 rounded-full bg-dmk-accent mt-2 flex-shrink-0"></span>
                  {detail}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
