---
import { cvData } from '../data/cvData';
---

<section class="border-b border-dmk-border/30 relative overflow-hidden">
  <!-- Background gradient effect -->
  <div class="absolute inset-0 gradient-mesh-premium opacity-30 pointer-events-none"></div>
  
  <div class="max-w-5xl mx-auto px-8 md:px-12 py-20 md:py-32 relative z-10">

    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-16 items-start">

      <div class="md:col-span-3 reveal-scale stagger-1">
        <div class="double-bezel">
          <div class="double-bezel-inner w-full aspect-[3/4] flex items-center justify-center hover-lift-premium overflow-hidden relative group">
            <div class="absolute inset-0 bg-gradient-to-br from-dmk-accent/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
            <span class="font-serif text-8xl opacity-80 text-dmk-accent group-hover:scale-110 transition-transform duration-700 cubic-bezier-[0.16,1,0.3,1] inline-block">N</span>
          </div>
        </div>
      </div>

      <div class="md:col-span-9 space-y-8">
        <div class="space-y-4 reveal stagger-1">
          <div class="font-sans text-[10px] uppercase tracking-[0.2em] font-semibold text-dmk-accent/80">
            PhD in Management · UAI
          </div>
          <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-bold leading-[1.1] text-dmk-text text-shadow-premium tracking-tight">
            {cvData.fullName}
          </h1>
          <p class="font-serif text-xl md:text-2xl italic text-dmk-muted leading-relaxed">
            {cvData.degree} · {cvData.institution}
          </p>
        </div>

        <div class="h-px w-32 bg-dmk-accent divider-animated reveal stagger-2"></div>

        <p class="font-sans text-lg leading-relaxed max-w-2xl text-dmk-text/90 reveal stagger-2">
          {cvData.bio}
        </p>

        <div class="flex flex-wrap gap-x-8 gap-y-3 text-sm text-dmk-muted reveal stagger-3">
          <span class="flex items-center gap-3 hover:text-dmk-accent transition-colors duration-500 cursor-default group">
            <span class="w-2 h-2 rounded-full bg-dmk-accent animate-pulse"></span>
            {cvData.email}
          </span>
          <span class="flex items-center gap-3 hover:text-dmk-accent transition-colors duration-500 cursor-default group">
            <span class="w-2 h-2 rounded-full bg-dmk-accent animate-pulse"></span>
            {cvData.phone}
          </span>
          <span class="flex items-center gap-3 hover:text-dmk-accent transition-colors duration-500 cursor-default group">
            <span class="w-2 h-2 rounded-full bg-dmk-accent animate-pulse"></span>
            Talca, Chile
          </span>
        </div>

        <div class="flex flex-wrap gap-3 pt-4 reveal stagger-3">
          {cvData.researchFields.map((field, i) => (
            <span class="font-sans text-xs px-4 py-2 bg-dmk-card border border-dmk-border/30 text-dmk-text hover:border-dmk-accent/50 hover:bg-dmk-accent/5 transition-all duration-500 cursor-default hover:-translate-y-1 hover:shadow-lg">
              {field}
            </span>
          ))}
        </div>

        <div class="flex border-b border-dmk-border/30 pt-8 reveal stagger-4 overflow-x-auto">
          {['Formación Académica', 'Publicaciones', 'Docencia', 'Experiencia', 'Contacto'].map((tab, i) => (
            <a href={`#${['academico','publicaciones','docencia','experiencia','contacto'][i]}`} class={`font-sans text-sm px-4 py-3 transition-all duration-500 whitespace-nowrap ${i === 0 ? 'border-b-[2px] border-dmk-accent text-dmk-accent font-semibold' : 'border-b-[2px] border-transparent text-dmk-muted hover:text-dmk-text hover:border-dmk-accent/30'}`}>
              {tab}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
