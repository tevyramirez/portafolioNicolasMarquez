---
import { cvData } from '../../data/cvData';
---

<section id="contacto" class="py-20 md:py-32">
  <div class="max-w-6xl mx-auto px-6 md:px-12">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
      <div class="md:col-span-7 space-y-8">
        <div class="font-serif text-sm text-dmk-accent italic tracking-wide">Contacto</div>
        <h2 class="font-serif text-4xl md:text-5xl font-light text-dmk-text leading-tight">
          Hablemos de <em class="font-semibold">Investigación</em>
        </h2>
        <p class="font-sans text-sm text-dmk-muted leading-relaxed max-w-md">
          Para colaboraciones académicas, publicaciones conjuntas o consultas de consultoría profesional.
        </p>
        <div class="space-y-4 pt-8">
          <div class="flex items-baseline gap-4">
            <span class="font-serif text-sm text-dmk-muted italic w-24">Email</span>
            <span class="font-sans text-sm text-dmk-accent">{cvData.email}</span>
          </div>
          <div class="flex items-baseline gap-4">
            <span class="font-serif text-sm text-dmk-muted italic w-24">Teléfono</span>
            <span class="font-sans text-sm text-dmk-text">{cvData.phone}</span>
          </div>
        </div>
      </div>

      <div class="md:col-span-5">
        <div class="space-y-3">
          <div class="font-serif text-sm text-dmk-muted italic mb-3">Referencias</div>
          {cvData.references.map((ref) => (
            <div class="border-l border-dmk-muted/30 pl-4 py-1">
              <p class="font-serif text-sm font-semibold text-dmk-text">{ref.name}</p>
              <p class="font-sans text-xs text-dmk-muted">{ref.institution}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
