---
import { cvData } from '../../data/cvData';
---

<section id="publicaciones" class="py-20 md:py-32 border-b border-dmk-muted/10">
  <div class="max-w-6xl mx-auto px-6 md:px-12">

    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 mb-16">
      <div class="md:col-span-4">
        <div class="font-serif text-sm text-dmk-accent italic tracking-wide mb-2">Producción Intelectual</div>
        <h2 class="font-serif text-4xl md:text-5xl font-light text-dmk-text leading-tight">
          <em class="font-semibold">Publicaciones</em>
        </h2>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
      {cvData.publications.slice(0, 10).map((pub) => (
        <article class="group space-y-3 border-b border-dmk-muted/10 pb-6">
          <div class="flex items-center gap-3">
            <span class="font-serif text-xs text-dmk-accent italic">{pub.status === 'in-press' ? 'In Press' : 'Publicado'}</span>
            <span class="h-px flex-1 bg-dmk-muted/20"></span>
            <span class="font-serif text-xs text-dmk-muted">{pub.year}</span>
          </div>
          <h3 class="font-serif text-lg font-semibold text-dmk-text group-hover:text-dmk-accent transition-colors leading-tight">
            {pub.title}
          </h3>
          <p class="font-sans text-xs text-dmk-muted italic">{pub.journal}</p>
          <p class="font-sans text-xs text-dmk-text/60">DOI: {pub.doi}</p>
        </article>
      ))}
    </div>
  </div>
</section>
