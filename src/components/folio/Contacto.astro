---
import { cvData } from '../../data/cvData';
---

<section id="contacto" class="py-12 md:py-16">
  <div class="max-w-5xl mx-auto px-6 md:px-8">
    <h2 class="font-serif text-2xl md:text-3xl font-bold text-dmk-text mb-6">Información de Contacto</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div class="space-y-4">
        <div>
          <div class="font-sans text-xs text-dmk-accent uppercase tracking-wider font-semibold">Email</div>
          <p class="font-sans text-sm text-dmk-text mt-1">{cvData.email}</p>
        </div>
        <div>
          <div class="font-sans text-xs text-dmk-accent uppercase tracking-wider font-semibold">Teléfono</div>
          <p class="font-sans text-sm text-dmk-text mt-1">{cvData.phone}</p>
        </div>
        <div>
          <div class="font-sans text-xs text-dmk-accent uppercase tracking-wider font-semibold">Afiliación</div>
          <p class="font-sans text-sm text-dmk-text mt-1">{cvData.workInstitution}</p>
          <p class="font-sans text-sm text-dmk-muted italic">{cvData.position}</p>
        </div>
      </div>

      <div>
        <div class="font-sans text-xs text-dmk-accent uppercase tracking-wider font-semibold mb-3">Referencias</div>
        <div class="space-y-3">
          {cvData.references.map((ref) => (
            <div class="border-l-2 border-dmk-accent pl-3 py-1">
              <p class="font-sans text-sm font-semibold text-dmk-text">{ref.name}</p>
              <p class="font-sans text-xs text-dmk-muted">{ref.institution}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
