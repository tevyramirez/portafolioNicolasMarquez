---
// The Folio DataAnalytics — Método científico formal, hipótesis, resultados
---

<section id="analisis-datos" class="py-12 md:py-16 border-b border-dmk-muted/20">
  <div class="max-w-5xl mx-auto px-6 md:px-8">
    
    <div class="mb-8">
      <h2 class="font-serif text-2xl md:text-3xl font-bold text-dmk-text mb-2">Servicios de Análisis de Datos</h2>
      <p class="font-sans text-sm text-dmk-muted">Metodologías cuantitativas para la toma de decisiones basada en evidencia.</p>
    </div>

    <!-- Método científico -->
    <div class="space-y-8">
      
      {[
        { 
          title: 'People Analytics Aplicado',
          method: 'Hipótesis: El clima afectivo medido mediante el modelo circumplejo de Russell (valencia × activación) predice significativamente la efectividad de equipos de innovación.',
          results: 'Implementación de modelos psicométricos basados en el modelo de valencia y activación de emociones para medir y optimizar la efectividad de equipos en el entorno de trabajo.',
          tools: 'Modelo Circumplex, Análisis Factorial Confirmatorio, R/Python'
        },
        { 
          title: 'Modelado Predictivo',
          method: 'Hipótesis: Algoritmos de machine learning supervisado pueden predecir el éxito de proyectos de corporate venturing con precisión superior a 85%.',
          results: 'Desarrollo de algoritmos personalizados para el pronóstico de éxito en corporate venturing y estimación de adopción de innovaciones tecnológicas mediante simulaciones Monte Carlo.',
          tools: 'Random Forest, XGBoost, Redes Neuronales, Python/TensorFlow'
        },
        { 
          title: 'Cuadros de Mando Interactivos',
          method: 'Hipótesis: La visualización en tiempo real de métricas clave de innovación y capital humano reduce el tiempo de respuesta gerencial en un 40%.',
          results: 'Demostraciones interactivas integradas en la interfaz corporativa que permiten explorar grandes volúmenes de datos transaccionales en tiempo real.',
          tools: 'Power BI, Tableau, D3.js, API REST'
        }
      ].map((item) => (
        <div class="border-l-2 border-dmk-accent pl-6 py-2 space-y-3">
          <h3 class="font-serif text-lg font-semibold text-dmk-text">{item.title}</h3>
          <div class="space-y-2">
            <div class="font-sans text-xs text-dmk-accent uppercase tracking-wider">Método</div>
            <p class="font-sans text-sm text-dmk-muted leading-relaxed">{item.method}</p>
          </div>
          <div class="space-y-2">
            <div class="font-sans text-xs text-dmk-accent uppercase tracking-wider">Resultados / Aplicación</div>
            <p class="font-sans text-sm text-dmk-muted leading-relaxed">{item.results}</p>
          </div>
          <div class="space-y-1">
            <div class="font-sans text-xs text-dmk-accent uppercase tracking-wider">Herramientas</div>
            <div class="font-sans text-sm text-dmk-text">{item.tools}</div>
          </div>
        </div>
      ))}

    </div>

  </div>
</section>
