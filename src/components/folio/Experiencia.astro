---
import { cvData } from '../../data/cvData';
---

<section id="experiencia" class="py-12 md:py-16 border-b border-dmk-muted/20">
  <div class="max-w-5xl mx-auto px-6 md:px-8">
    <h2 class="font-serif text-2xl md:text-3xl font-bold text-dmk-text mb-6">Experiencia Profesional</h2>

    <div class="space-y-6">
      {cvData.professionalExperience.map((exp) => (
        <div class="grid grid-cols-1 md:grid-cols-12 gap-3">
          <div class="md:col-span-3 font-sans text-sm text-dmk-muted">{exp.period}</div>
          <div class="md:col-span-9">
            <h3 class="font-serif text-base font-semibold text-dmk-text">{exp.role.es}</h3>
            <p class="font-sans text-sm text-dmk-muted italic">{exp.organization}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
