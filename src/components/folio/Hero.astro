---
// The Folio Hero — Académico Clásico, Institucional, Harvard-style
---

<section class="relative bg-dmk-bg border-b border-dmk-muted/20">
  
  <!-- Banner institucional con header -->
  <div class="max-w-5xl mx-auto px-6 md:px-8 py-12 md:py-16">
    
    <!-- Breadcrumb institucional -->
    <div class="font-sans text-xs text-dmk-muted mb-8">
      Inicio / Perfiles / Escuela de Negocios / Management
    </div>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-start">
      
      <!-- Foto del académico (3 cols) -->
      <div class="md:col-span-3">
        <div class="aspect-[3/4] bg-dmk-card border border-dmk-muted/20 flex items-center justify-center">
          <div class="w-24 h-24 rounded-full bg-dmk-accent/10 flex items-center justify-center">
            <span class="font-serif text-4xl text-dmk-accent">N</span>
          </div>
        </div>
      </div>

      <!-- Info del académico (9 cols) -->
      <div class="md:col-span-9 space-y-6">
        
        <div class="space-y-2">
          <h1 class="font-serif text-3xl md:text-4xl font-bold text-dmk-text">
            Dr. Nicolás Márquez
          </h1>
          <p class="font-sans text-base text-dmk-muted">
            Doctor en Management · Profesor Escuela de Negocios<br/>
            Universidad Adolfo Ibáñez · Santiago, Chile
          </p>
        </div>

        <!-- Líneas de contacto institucional -->
        <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-dmk-muted">
          <span class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-dmk-accent"></span>
            nmarquez@uai.cl
          </span>
          <span class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-dmk-accent"></span>
            ORCID: 0000-0000-0000-0000
          </span>
          <span class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-dmk-accent"></span>
            Scopus Author ID: 12345678
          </span>
        </div>

        <!-- Tabs de navegación -->
        <div class="flex border-b border-dmk-muted/20 pt-4">
          {['Biografía', 'Investigación', 'Publicaciones', 'Consultoría', 'Contacto'].map((tab, i) => (
            <a href={`#${['','','publicaciones','consultoria','contacto'][i]}`} 
               class={`font-sans text-sm px-4 py-2 border-b-2 transition-colors ${i === 0 ? 'border-dmk-accent text-dmk-accent font-semibold' : 'border-transparent text-dmk-muted hover:text-dmk-text'}`}>
              {tab}
            </a>
          ))}
        </div>

      </div>
    </div>

  </div>
</section>
