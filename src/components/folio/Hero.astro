---
import { cvData } from '../../data/cvData';
---

<section class="relative bg-dmk-bg border-b border-dmk-muted/20">
  <div class="max-w-5xl mx-auto px-6 md:px-8 py-12 md:py-16">
    <div class="font-mono text-xs text-dmk-muted mb-8">
      Inicio / Perfiles / Escuela de Negocios / Management
    </div>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-start">
      <div class="md:col-span-3">
        <div class="aspect-[3/4] bg-dmk-card border card-3d border-dmk-muted/20 flex items-center justify-center">
          <div class="w-24 h-24 rounded-full bg-dmk-accent/10 flex items-center justify-center">
            <span class="font-serif text-4xl text-dmk-accent">N</span>
          </div>
        </div>
      </div>

      <div class="md:col-span-9 space-y-6">
        <div class="space-y-2">
          <h1 class="font-serif text-3xl md:text-4xl font-bold text-dmk-text">
            {cvData.fullName}
          </h1>
          <p class="font-sans text-base text-dmk-muted">
            {cvData.degree} · {cvData.position}<br/>
            {cvData.institution} · Talca, Chile
          </p>
        </div>

        <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-dmk-muted">
          <span class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-dmk-accent"></span>
            {cvData.email}
          </span>
          <span class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-dmk-accent"></span>
            {cvData.phone}
          </span>
        </div>

        <div class="flex border-b border-dmk-muted/20 pt-4">
          {['Biografía', 'Formación', 'Publicaciones', 'Docencia', 'Contacto'].map((tab, i) => (
            <a href={`#${['','academico','publicaciones','docencia','contacto'][i]}`} class={`font-sans text-sm px-4 py-2 border-b-2 transition-colors ${i === 0 ? 'border-dmk-accent text-dmk-accent font-semibold' : 'border-transparent text-dmk-muted hover:text-dmk-text'}`}>
              {tab}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
