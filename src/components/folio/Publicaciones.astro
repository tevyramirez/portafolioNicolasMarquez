---
import { cvData } from '../../data/cvData';
---

<section id="publicaciones" class="py-12 md:py-16 border-b border-dmk-muted/20">
  <div class="max-w-5xl mx-auto px-6 md:px-8">
    <h2 class="font-serif text-2xl md:text-3xl font-bold text-dmk-text mb-6">Publicaciones Científicas</h2>

    <div class="space-y-5">
      {cvData.publications.slice(0, 12).map((pub) => (
        <div class="space-y-1">
          <p class="font-sans text-sm text-dmk-text leading-relaxed pl-4 -indent-4">
            <strong>{pub.authors}</strong> ({pub.year}). {pub.title}. <em class="text-dmk-muted">{pub.journal}</em>{pub.doi && <span class="text-xs text-dmk-muted">. DOI: {pub.doi}</span>}.
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
