---
import { cvData as cvDataEs } from '../../data/cvData';
import { cvData as cvDataEn } from '../../data/cvData_en';
import { t } from '../../i18n/ui';
import { getLocale } from '../../i18n/utils';

const locale = getLocale(Astro.url);
const d = locale === 'en' ? cvDataEn : cvDataEs;
---

<section id="bi" class="py-12 md:py-16">
  <div class="max-w-5xl mx-auto px-8 md:px-12">
    
    <div class="mb-10">
      <h2 class="font-serif text-2xl font-bold text-dmk-text mb-2">{t(locale, 'section.bi')}</h2>
    </div>

    <!-- Datametrik Card -->
    <div class="bg-[#F4FAF9] border border-[#2EC4B6]/20 rounded-sm overflow-hidden relative">
      
      <!-- Canvas Background -->
      <canvas id="datametrik-canvas" class="absolute inset-0 w-full h-full opacity-40"></canvas>
      
      <div class="relative z-10 p-8 md:p-12 space-y-8">
        
        <!-- Header with tagline -->
        <div class="space-y-4">
          <div class="flex items-center gap-3">
            <div class="bg-white rounded shadow-sm px-4 py-3">
              <img src="/datametrik-logo.png" alt="DATAMETRIK" class="h-16 w-auto" />
            </div>
          </div>
          <p class="font-serif text-lg italic text-[#0D9488] border-l-2 border-[#2EC4B6] pl-4">
            {d.datametrik.tagline}
          </p>
        </div>

        <!-- Description -->
        <p class="font-sans text-base text-dmk-muted leading-relaxed max-w-2xl">
          {d.datametrik.description}
        </p>

        <!-- Services -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {d.datametrik.services.map((service) => (
            <div class="flex items-start gap-3">
              <span class="w-1.5 h-1.5 rounded-full bg-[#2EC4B6] mt-2 flex-shrink-0"></span>
              <p class="font-sans text-sm text-dmk-muted leading-relaxed">{service}</p>
            </div>
          ))}
        </div>

        <!-- Methodology 7 etapas -->
        <div class="space-y-4">
          <h4 class="font-sans text-sm font-semibold text-[#0D9488] uppercase tracking-wider">{t(locale, 'label.metodologia')}</h4>
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
            {d.datametrik.methodology.map((step) => (
              <div class="space-y-2 p-3 rounded bg-white/60">
                <div class="font-serif text-2xl font-bold text-[#2EC4B6]/30">{step.step}</div>
                <h5 class="font-sans text-sm font-semibold text-dmk-text">{step.title}</h5>
                <p class="font-sans text-xs text-dmk-muted leading-relaxed">{step.description}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Contact & CTA -->
        <div class="flex flex-wrap items-center gap-4 pt-4 border-t border-[#2EC4B6]/20">
          <div class="font-sans text-sm text-dmk-muted">
            {d.datametrik.contact} · {d.datametrik.phone}
          </div>
          <a href={d.datametrik.url} class="ml-auto font-sans text-sm font-semibold text-[#0D9488] hover:text-[#14B8A6] transition-colors duration-300 flex items-center gap-2 group">
            {t(locale, 'label.visitar')} {d.datametrik.name}
            <span class="inline-block group-hover:translate-x-1 transition-transform duration-300">→</span>
          </a>
        </div>

      </div>
    </div>

  </div>
</section>

<script>
  (function() {
    var canvas = document.getElementById('datametrik-canvas');
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    if (!ctx) return;

    var width = canvas.offsetWidth;
    var height = canvas.offsetHeight;
    canvas.width = width * window.devicePixelRatio;
    canvas.height = height * window.devicePixelRatio;
    ctx.scale(window.devicePixelRatio, window.devicePixelRatio);

    var nodes = [];
    var nodeCount = 25;
    var connectionDistance = 120;
    var mouse = { x: -1000, y: -1000 };
    var animId = null;

    for (var i = 0; i < nodeCount; i++) {
      nodes.push({
        x: Math.random() * width,
        y: Math.random() * height,
        vx: (Math.random() - 0.5) * 0.5,
        vy: (Math.random() - 0.5) * 0.5,
        radius: Math.random() * 2 + 1
      });
    }

    function animate() {
      if (!ctx) return;
      ctx.clearRect(0, 0, width, height);

      nodes.forEach(function(node) {
        node.x += node.vx;
        node.y += node.vy;

        if (node.x < 0 || node.x > width) node.vx *= -1;
        if (node.y < 0 || node.y > height) node.vy *= -1;

        var dx = node.x - mouse.x;
        var dy = node.y - mouse.y;
        var dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < 100) {
          var force = (100 - dist) / 100;
          node.vx += (dx / dist) * force * 0.5;
          node.vy += (dy / dist) * force * 0.5;
        }

        ctx.beginPath();
        ctx.arc(node.x, node.y, node.radius, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(46, 196, 182, 0.4)';
        ctx.fill();
      });

      for (var i = 0; i < nodes.length; i++) {
        for (var j = i + 1; j < nodes.length; j++) {
          var dx = nodes[i].x - nodes[j].x;
          var dy = nodes[i].y - nodes[j].y;
          var dist = Math.sqrt(dx * dx + dy * dy);

          if (dist < connectionDistance) {
            ctx.beginPath();
            ctx.moveTo(nodes[i].x, nodes[i].y);
            ctx.lineTo(nodes[j].x, nodes[j].y);
            ctx.strokeStyle = 'rgba(46, 196, 182, ' + (1 - dist / connectionDistance) * 0.2 + ')';
            ctx.lineWidth = 0.5;
            ctx.stroke();
          }
        }
      }

      animId = requestAnimationFrame(animate);
    }

    // Pause/resume based on visibility
    var section = canvas.closest('section');
    if (section) {
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            if (!animId) animate();
          } else {
            if (animId) { cancelAnimationFrame(animId); animId = null; }
          }
        });
      }, { threshold: 0.1 });
      observer.observe(section);
    }

    animate();

    var parent = canvas.parentElement;
    if (parent) {
      parent.addEventListener('mousemove', function(e) {
        var rect = canvas.getBoundingClientRect();
        mouse.x = e.clientX - rect.left;
        mouse.y = e.clientY - rect.top;
      });

      parent.addEventListener('mouseleave', function() {
        mouse.x = -1000;
        mouse.y = -1000;
      });
    }

    window.addEventListener('resize', function() {
      width = canvas.offsetWidth;
      height = canvas.offsetHeight;
      canvas.width = width * window.devicePixelRatio;
      canvas.height = height * window.devicePixelRatio;
      ctx.setTransform(window.devicePixelRatio, 0, 0, window.devicePixelRatio, 0, 0);
    });
  })();
</script>
