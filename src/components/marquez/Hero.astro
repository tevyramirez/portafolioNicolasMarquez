---
import { cvData } from '../../data/cvData';
---

<section id="perfil" class="relative bg-dmk-bg border-b border-dmk-border">
  <div class="max-w-5xl mx-auto px-8 md:px-12 py-16 md:py-20">
    
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 items-start">
      
      <!-- Foto (3 cols) -->
      <div class="md:col-span-3 reveal-scale stagger-1">
        <div class="aspect-[3/4] bg-dmk-card border-2 border-dmk-accent flex items-center justify-center overflow-hidden">
          <img src="/photo.jpg" alt="Dr. Nicolás Márquez Álvarez" class="w-full h-full object-cover" onerror="this.style.display='none'; this.parentElement.innerHTML='<div class=\'w-full h-full flex items-center justify-center\'><span class=\'font-serif text-6xl text-dmk-accent\'>N</span></div>';" />
        </div>
      </div>

      <!-- Info (9 cols) -->
      <div class="md:col-span-9 space-y-6">
        
        <div class="space-y-2 reveal stagger-1">
          <h1 class="font-serif text-3xl md:text-4xl font-bold text-dmk-text">
            {cvData.fullName}
          </h1>
          <p class="font-serif text-lg text-dmk-muted italic">
            {cvData.degree}, {cvData.institution}
          </p>
        </div>

        <div class="h-px w-24 bg-dmk-accent divider-animated reveal stagger-2"></div>

        <p class="font-sans text-base text-dmk-text leading-relaxed max-w-2xl reveal stagger-2">
          {cvData.bio}
        </p>

        <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-dmk-muted reveal stagger-3">
          <span class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-dmk-accent"></span>
            {cvData.email}
          </span>
          <span class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-dmk-accent"></span>
            {cvData.phone}
          </span>
          <span class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-dmk-accent"></span>
            Talca, Chile
          </span>
        </div>

        <!-- Social Links -->
        <div class="flex flex-wrap gap-3 pt-2 reveal stagger-3">
          <a href={cvData.social.linkedin} class="font-mono text-[10px] uppercase tracking-[0.15em] text-dmk-accent border border-dmk-accent/30 px-3 py-1.5 rounded-sm hover:bg-dmk-accent hover:text-white transition-all duration-300">
            LinkedIn
          </a>
          <a href={cvData.social.orcid} class="font-mono text-[10px] uppercase tracking-[0.15em] text-dmk-accent border border-dmk-accent/30 px-3 py-1.5 rounded-sm hover:bg-dmk-accent hover:text-white transition-all duration-300">
            ORCID
          </a>
          <a href={cvData.social.googleScholar} class="font-mono text-[10px] uppercase tracking-[0.15em] text-dmk-accent border border-dmk-accent/30 px-3 py-1.5 rounded-sm hover:bg-dmk-accent hover:text-white transition-all duration-300">
            Google Scholar
          </a>
        </div>

      </div>
    </div>

  </div>
</section>
