---
const tabs = [
  { id: 'perfil', label: 'Perfil' },
  { id: 'formacion', label: 'Formación' },
  { id: 'publicaciones', label: 'Publicaciones' },
  { id: 'docencia', label: 'Docencia' },
  { id: 'experiencia', label: 'Experiencia' },
  { id: 'servicios', label: 'Servicios' },
  { id: 'bi', label: 'Business Intelligence' },
  { id: 'contacto', label: 'Contacto' }
];
---

<nav class="nav-sticky">
  <div class="max-w-5xl mx-auto px-8 md:px-12">
    <div class="flex items-center gap-1 overflow-x-auto py-3 scrollbar-hide">
      {tabs.map((tab, i) => (
        <a 
          href={`#${tab.id}`} 
          class={`font-sans text-xs px-3 py-2 whitespace-nowrap transition-colors duration-300 rounded-sm ${i === 0 ? 'text-dmk-accent font-semibold bg-dmk-accent/5' : 'text-dmk-muted hover:text-dmk-text hover:bg-dmk-accent/5'}`}
        >
          {tab.label}
        </a>
      ))}
      <div class="ml-auto flex items-center gap-1 pl-3 border-l border-dmk-border">
        <button id="theme-duran" class="theme-btn font-mono text-[10px] px-2 py-1.5 rounded-sm uppercase tracking-wider transition-all duration-300 border" title="Paleta Durán (Azul)">
          D
        </button>
        <button id="theme-symmes" class="theme-btn font-mono text-[10px] px-2 py-1.5 rounded-sm uppercase tracking-wider transition-all duration-300 border" title="Paleta Symmes (Rojo)">
          S
        </button>
      </div>
    </div>
  </div>
</nav>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .theme-btn {
    border-color: var(--color-dmk-border);
    color: var(--color-dmk-muted);
    background: transparent;
  }
  .theme-btn:hover {
    border-color: var(--color-dmk-accent);
    color: var(--color-dmk-accent);
  }
  .theme-btn.active {
    border-color: var(--color-dmk-accent);
    color: var(--color-dmk-accent);
    font-weight: 600;
  }
</style>

<script>
  (function() {
    var current = localStorage.getItem('marquez-theme') || 'duran';
    document.documentElement.setAttribute('data-theme', current);

    function setTheme(theme) {
      document.documentElement.setAttribute('data-theme', theme);
      localStorage.setItem('marquez-theme', theme);
      document.querySelectorAll('.theme-btn').forEach(function(btn) {
        btn.classList.toggle('active', btn.id === 'theme-' + theme);
      });
    }

    document.addEventListener('DOMContentLoaded', function() {
      setTheme(current);
      document.getElementById('theme-duran').addEventListener('click', function() { setTheme('duran'); });
      document.getElementById('theme-symmes').addEventListener('click', function() { setTheme('symmes'); });
    });
  })();
</script>
