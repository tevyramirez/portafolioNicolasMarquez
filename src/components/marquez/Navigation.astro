---
import { t } from '../../i18n/ui';
import { getLocale, getOtherUrl } from '../../i18n/utils';

const locale = getLocale(Astro.url);

const tabs = [
  { id: 'perfil', key: 'nav.perfil' as const },
  { id: 'formacion', key: 'nav.formacion' as const },
  { id: 'publicaciones', key: 'nav.publicaciones' as const },
  { id: 'docencia', key: 'nav.docencia' as const },
  { id: 'experiencia', key: 'nav.experiencia' as const },
  { id: 'servicios', key: 'nav.servicios' as const },
  { id: 'bi', key: 'nav.bi' as const },
  { id: 'contacto', key: 'nav.contacto' as const },
];
---

<nav class="nav-sticky">
  <div class="max-w-5xl mx-auto px-8 md:px-12">
    <div class="flex items-center gap-1 overflow-x-auto py-3 scrollbar-hide">
      {tabs.map((tab, i) => (
        <a
          href={`#${tab.id}`}
          class={`font-sans text-xs px-3 py-2 whitespace-nowrap transition-colors duration-300 rounded-sm ${i === 0 ? 'text-dmk-accent font-semibold bg-dmk-accent/5' : 'text-dmk-muted hover:text-dmk-text hover:bg-dmk-accent/5'}`}
        >
          {t(locale, tab.key as any)}
        </a>
      ))}
      <div class="ml-auto flex items-center gap-1 pl-3 border-l border-dmk-border">
        <button id="theme-duran" class="theme-btn font-mono text-[10px] px-2 py-1.5 rounded-sm uppercase tracking-wider transition-all duration-300 border" aria-label={t(locale, 'theme.duran')}>
          D
        </button>
        <button id="theme-symmes" class="theme-btn font-mono text-[10px] px-2 py-1.5 rounded-sm uppercase tracking-wider transition-all duration-300 border" aria-label={t(locale, 'theme.symmes')}>
          S
        </button>
        <a href={getOtherUrl(Astro.url)} class="font-mono text-[10px] uppercase tracking-[0.15em] px-2 py-1.5 rounded-sm border text-dmk-muted hover:text-dmk-accent hover:border-dmk-accent transition-colors" aria-label={locale === 'en' ? t('es', 'lang.switch.en') : t('en', 'lang.switch')}>
          {locale === 'en' ? 'ES' : 'EN'}
        </a>
      </div>
    </div>
  </div>
</nav>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .theme-btn {
    border-color: var(--color-dmk-border);
    color: var(--color-dmk-muted);
    background: transparent;
  }
  .theme-btn:hover {
    border-color: var(--color-dmk-accent);
    color: var(--color-dmk-accent);
  }
  .theme-btn.active {
    border-color: var(--color-dmk-accent);
    color: var(--color-dmk-accent);
    font-weight: 600;
  }
</style>

<script>
  (function() {
    var current = localStorage.getItem('marquez-theme') || 'duran';
    document.documentElement.setAttribute('data-theme', current);

    function setTheme(theme) {
      document.documentElement.setAttribute('data-theme', theme);
      localStorage.setItem('marquez-theme', theme);
      document.querySelectorAll('.theme-btn').forEach(function(btn) {
        btn.classList.toggle('active', btn.id === 'theme-' + theme);
      });
    }

    document.addEventListener('DOMContentLoaded', function() {
      setTheme(current);
      document.getElementById('theme-duran').addEventListener('click', function() { setTheme('duran'); });
      document.getElementById('theme-symmes').addEventListener('click', function() { setTheme('symmes'); });
    });
  })();
</script>
