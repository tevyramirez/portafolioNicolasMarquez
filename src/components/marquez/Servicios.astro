---
import { cvData } from '../../data/cvData';
---

<section id="servicios" class="py-12 md:py-16 border-b border-dmk-border">
  <div class="max-w-5xl mx-auto px-8 md:px-12">
    
    <div class="mb-10">
      <h2 class="font-serif text-2xl font-bold text-dmk-text mb-2">Servicios de Consultoría</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      
      {cvData.services.map((service, i) => (
        <div class="card-marquez p-6 space-y-4 group">
          <div class="flex items-start gap-4">
            <span class="font-serif text-3xl font-bold text-dmk-accent/20 group-hover:text-dmk-accent/40 transition-colors duration-300">
              {service.number}
            </span>
            <div class="space-y-2">
              <h3 class="font-serif text-lg font-semibold text-dmk-text group-hover:text-dmk-accent transition-colors duration-300">
                {service.title}
              </h3>
              <p class="font-sans text-sm text-dmk-muted leading-relaxed">
                {service.description}
              </p>
            </div>
          </div>
        </div>
      ))}

    </div>

  </div>
</section>
