---
import { cvData } from '../../data/cvData';
---

<section id="academico" class="py-20 md:py-32 border-b border-dmk-muted/10">
  <div class="max-w-6xl mx-auto px-6 md:px-12">
    <div class="mb-16">
      <div class="font-mono text-xs text-dmk-accent uppercase tracking-widest mb-4">02 / Academic Background</div>
      <h2 class="font-mono text-4xl md:text-5xl font-bold text-dmk-text uppercase tracking-tight">FORMACIÓN</h2>
    </div>

    <div class="space-y-12">
      {cvData.education.map((edu) => (
        <div class="border-l-2 border-dmk-accent pl-6 py-2">
          <div class="font-mono text-xs text-dmk-muted uppercase tracking-wider mb-2">{edu.period}</div>
          <h3 class="font-mono text-xl font-bold text-dmk-text uppercase">{edu.degree}</h3>
          <p class="font-mono text-sm text-dmk-muted mt-1">{edu.institution}</p>
          <ul class="mt-3 space-y-1 font-sans text-sm text-dmk-text/80">
            {edu.details.map((detail) => (
              <li>• {detail}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
