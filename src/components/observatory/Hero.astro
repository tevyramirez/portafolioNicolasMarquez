---
import { cvData } from '../../data/cvData';
---

<section class="relative min-h-screen flex flex-col justify-center overflow-hidden">

  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--color-dmk-card)_0%,_var(--color-dmk-bg)_70%)]"></div>
    <!-- Animated particles with CSS -->
    <div class="absolute inset-0 opacity-40">
      <div class="absolute w-1 h-1 rounded-full bg-dmk-accent particle" style="left: 15%; top: 20%; animation-delay: 0s;"></div>
      <div class="absolute w-1 h-1 rounded-full bg-dmk-accent particle" style="left: 28%; top: 65%; animation-delay: 1s;"></div>
      <div class="absolute w-1 h-1 rounded-full bg-dmk-accent particle" style="left: 42%; top: 30%; animation-delay: 2s;"></div>
      <div class="absolute w-1 h-1 rounded-full bg-dmk-accent particle" style="left: 58%; top: 75%; animation-delay: 0.5s;"></div>
      <div class="absolute w-1 h-1 rounded-full bg-dmk-accent particle" style="left: 70%; top: 25%; animation-delay: 1.5s;"></div>
      <div class="absolute w-1 h-1 rounded-full bg-dmk-accent particle" style="left: 82%; top: 55%; animation-delay: 2.5s;"></div>
      <div class="absolute w-1 h-1 rounded-full bg-dmk-accent particle" style="left: 90%; top: 35%; animation-delay: 0.8s;"></div>
      <div class="absolute w-1.5 h-1.5 rounded-full bg-dmk-accent particle" style="left: 10%; top: 80%; animation-delay: 1.2s;"></div>
      <div class="absolute w-1.5 h-1.5 rounded-full bg-dmk-accent particle" style="left: 35%; top: 10%; animation-delay: 2.2s;"></div>
      <div class="absolute w-1 h-1 rounded-full bg-dmk-accent particle" style="left: 65%; top: 90%; animation-delay: 3s;"></div>
      <div class="absolute w-1 h-1 rounded-full bg-dmk-accent particle" style="left: 95%; top: 15%; animation-delay: 0.3s;"></div>
      <div class="absolute w-1.5 h-1.5 rounded-full bg-dmk-accent particle" style="left: 50%; top: 50%; animation-delay: 1.8s;"></div>
    </div>
    <!-- Constellation lines effect -->
    <svg class="absolute inset-0 w-full h-full opacity-10 pointer-events-none" xmlns="http://www.w3.org/2000/svg">
      <line x1="15%" y1="20%" x2="42%" y2="30%" class="constellation-line" style="animation-delay: 0s;" />
      <line x1="42%" y1="30%" x2="70%" y2="25%" class="constellation-line" style="animation-delay: 0.5s;" />
      <line x1="28%" y1="65%" x2="58%" y2="75%" class="constellation-line" style="animation-delay: 1s;" />
      <line x1="58%" y1="75%" x2="82%" y2="55%" class="constellation-line" style="animation-delay: 1.5s;" />
      <line x1="70%" y1="25%" x2="90%" y2="35%" class="constellation-line" style="animation-delay: 2s;" />
    </svg>
  </div>

  <div class="relative z-10 px-6 md:px-12 lg:px-20 max-w-6xl">

    <div class="space-y-2 mb-12 reveal stagger-1">
      <div class="font-mono text-[10px] text-dmk-accent uppercase tracking-[0.3em] text-glow">
        {cvData.degree} · {cvData.institution}
      </div>
    </div>

    <h1 class="font-mono text-5xl sm:text-7xl md:text-8xl lg:text-9xl font-bold text-dmk-text leading-[0.9] tracking-tighter uppercase reveal stagger-2">
      Rigor<br/>
      <span class="text-dmk-accent text-glow">Científico</span>
    </h1>

    <div class="h-px w-32 bg-dmk-accent mt-8 divider-animated reveal stagger-3"></div>

    <p class="font-mono text-sm md:text-base text-dmk-muted max-w-lg leading-relaxed mt-8 uppercase tracking-wide reveal stagger-4">
      {cvData.bio}
    </p>

    <div class="mt-16 grid grid-cols-3 gap-8 max-w-md reveal stagger-5">
      <div class="space-y-1 group cursor-default">
        <div class="font-mono text-3xl font-bold text-dmk-accent group-hover:scale-110 transition-transform duration-300 inline-block">{cvData.publications.length}</div>
        <div class="font-mono text-[10px] text-dmk-muted uppercase tracking-wider group-hover:text-dmk-accent transition-colors duration-300">Publicaciones</div>
      </div>
      <div class="space-y-1 group cursor-default">
        <div class="font-mono text-3xl font-bold text-dmk-accent group-hover:scale-110 transition-transform duration-300 inline-block">{cvData.academicPositions.length}</div>
        <div class="font-mono text-[10px] text-dmk-muted uppercase tracking-wider group-hover:text-dmk-accent transition-colors duration-300">Posiciones</div>
      </div>
      <div class="space-y-1 group cursor-default">
        <div class="font-mono text-3xl font-bold text-dmk-accent group-hover:scale-110 transition-transform duration-300 inline-block">{cvData.researchFields.length}</div>
        <div class="font-mono text-[10px] text-dmk-muted uppercase tracking-wider group-hover:text-dmk-accent transition-colors duration-300">Áreas</div>
      </div>
    </div>
  </div>
  
  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 z-10 flex flex-col items-center gap-2 opacity-50">
    <div class="font-mono text-[10px] text-dmk-muted uppercase tracking-wider">Scroll</div>
    <div class="w-px h-8 bg-dmk-accent" style="animation: scroll-indicator 2s ease-in-out infinite;"></div>
  </div>
</section>
