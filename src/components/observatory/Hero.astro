---
// The Observatory Hero — Experimental, Inmersivo, 3D Partículas
---

<section class="relative min-h-screen flex flex-col justify-center overflow-hidden">
  
  <!-- Background: Partículas de datos flotantes (CSS 3D) -->
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--color-dmk-card)_0%,_var(--color-dmk-bg)_70%)]"></div>
    
    <!-- Grid de partículas flotantes -->
    <div class="absolute inset-0 opacity-30">
      {[...Array(20)].map((_, i) => (
        <div 
          class="absolute rounded-full bg-dmk-accent/20"
          style={{
            width: `${Math.random() * 4 + 1}px`,
            height: `${Math.random() * 4 + 1}px`,
            left: `${Math.random() * 100}%`,
            top: `${Math.random() * 100}%`,
            animation: `float ${Math.random() * 10 + 5}s ease-in-out infinite`,
            animationDelay: `${Math.random() * 5}s`
          }}
        />
      ))}
    </div>
  </div>

  <!-- Navegación lateral flotante derecha -->
  <nav class="fixed right-6 top-1/2 -translate-y-1/2 z-50 hidden lg:flex flex-col gap-3">
    {['Inicio', 'Servicios', 'Investigación', 'Datos', 'Contacto'].map((item, i) => (
      <a href={`#${['','consultoria','publicaciones','analisis-datos','contacto'][i]}`} class="group flex items-center gap-3 text-right">
        <span class="font-mono text-[10px] text-dmk-muted opacity-0 group-hover:opacity-100 transition-opacity">{item}</span>
        <span class="w-2 h-2 rounded-full bg-dmk-muted group-hover:bg-dmk-accent transition-colors"></span>
      </a>
    ))}
  </nav>

  <!-- Contenido principal: Monospace gigante, full-width -->
  <div class="relative z-10 px-6 md:px-12 lg:px-20 max-w-6xl">
    
    <!-- Nombre en monospace gigante, alineado izquierda -->
    <div class="space-y-2">
      <div class="font-mono text-[10px] text-dmk-accent uppercase tracking-[0.3em] mb-6">
        Dr. Nicolás Márquez · PhD Management · UAI
      </div>
      
      <h1 class="font-mono text-5xl sm:text-7xl md:text-8xl lg:text-9xl font-bold text-dmk-text leading-[0.9] tracking-tighter uppercase">
        Rigor<br/>
        <span class="text-dmk-accent">Científico</span>
      </h1>
      
      <div class="h-px w-32 bg-dmk-accent mt-8"></div>
      
      <p class="font-mono text-sm md:text-base text-dmk-muted max-w-lg leading-relaxed mt-8 uppercase tracking-wide">
        Consultoría de dirección basada en evidencia. Modelos predictivos para la toma de decisiones empresariales en Chile y Latinoamérica.
      </p>
    </div>

    <!-- Stats flotantes -->
    <div class="mt-16 grid grid-cols-3 gap-8 max-w-md">
      <div class="space-y-1">
        <div class="font-mono text-3xl font-bold text-dmk-accent">47</div>
        <div class="font-mono text-[10px] text-dmk-muted uppercase tracking-wider">Publicaciones</div>
      </div>
      <div class="space-y-1">
        <div class="font-mono text-3xl font-bold text-dmk-accent">23</div>
        <div class="font-mono text-[10px] text-dmk-muted uppercase tracking-wider">H-Index</div>
      </div>
      <div class="space-y-1">
        <div class="font-mono text-3xl font-bold text-dmk-accent">1.2K</div>
        <div class="font-mono text-[10px] text-dmk-muted uppercase tracking-wider">Citas</div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-12 left-6 md:left-12 lg:left-20 flex items-center gap-3">
      <div class="w-px h-12 bg-dmk-accent animate-pulse"></div>
      <span class="font-mono text-[10px] text-dmk-muted uppercase tracking-wider rotate-90 origin-left translate-x-3">Scroll</span>
    </div>
  </div>

  <style>
    @keyframes float {
      0%, 100% { transform: translateY(0) translateX(0); opacity: 0.3; }
      25% { transform: translateY(-20px) translateX(10px); opacity: 0.8; }
      50% { transform: translateY(10px) translateX(-10px); opacity: 0.5; }
      75% { transform: translateY(-10px) translateX(5px); opacity: 0.7; }
    }
  </style>
</section>
