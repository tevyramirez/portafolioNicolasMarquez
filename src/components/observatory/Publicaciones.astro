---
import { cvData } from '../../data/cvData';
---

<section id="publicaciones" class="py-20 md:py-32 border-b border-dmk-muted/10">
  <div class="max-w-6xl mx-auto px-6 md:px-12">
    <div class="mb-16">
      <div class="font-mono text-xs text-dmk-accent uppercase tracking-widest mb-4">03 / Research Output</div>
      <h2 class="font-mono text-4xl md:text-5xl font-bold text-dmk-text uppercase tracking-tight">PUBLICACIONES</h2>
    </div>

    <div class="relative">
      <div class="flex gap-6 overflow-x-auto pb-8 snap-x snap-mandatory">
        {cvData.publications.slice(0, 10).map((pub) => (
          <div class="flex-shrink-0 w-80 snap-start">
            <div class="h-full border border-dmk-muted/20 bg-dmk-card/30 p-6 space-y-4 hover:border-dmk-accent/40 transition-colors">
              <div class="flex justify-between items-center">
                <div class="font-mono text-[10px] text-dmk-accent uppercase tracking-wider">{pub.status === 'in-press' ? 'In Press' : 'Published'}</div>
                <div class="font-mono text-[10px] text-dmk-muted">{pub.year}</div>
              </div>
              <h3 class="font-mono text-sm font-bold text-dmk-text leading-tight">{pub.title}</h3>
              <p class="font-mono text-xs text-dmk-muted">{pub.authors.split(',')[0]}{pub.correspondingAuthor ? ' *' : ''}</p>
              <p class="font-mono text-[10px] text-dmk-muted/60">{pub.journal}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="mt-8 text-center font-mono text-[10px] text-dmk-muted">
      ← Desliza horizontalmente · {cvData.publications.length} publicaciones en total →
    </div>
  </div>
</section>
