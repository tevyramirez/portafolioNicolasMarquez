---
// The Swiss Contact — Grid form, técnico, brutalista
---

<section id="contacto" class="py-16 md:py-24 border-t border-dmk-muted/20">
  <div class="max-w-6xl mx-auto px-4 md:px-8">
    
    <div class="mb-12">
      <div class="font-mono text-[10px] text-dmk-muted uppercase tracking-wider mb-2">04 / CONTACT</div>
      <h2 class="font-mono text-3xl md:text-4xl font-bold text-dmk-text uppercase tracking-tight">CONTACT</h2>
    </div>

    <form class="grid grid-cols-2 md:grid-cols-4 gap-0 border border-dmk-muted/20">
      <div class="col-span-2 md:col-span-1 border-r border-b border-dmk-muted/20 p-4">
        <label class="font-mono text-[10px] text-dmk-muted uppercase block mb-2">Name</label>
        <input type="text" class="w-full bg-transparent font-mono text-sm text-dmk-text focus:outline-none placeholder:text-dmk-muted/50"/>
      </div>
      <div class="col-span-2 md:col-span-1 border-r border-b border-dmk-muted/20 p-4">
        <label class="font-mono text-[10px] text-dmk-muted uppercase block mb-2">Email</label>
        <input type="email" class="w-full bg-transparent font-mono text-sm text-dmk-text focus:outline-none placeholder:text-dmk-muted/50"/>
      </div>
      <div class="col-span-2 md:col-span-1 border-r border-b border-dmk-muted/20 p-4">
        <label class="font-mono text-[10px] text-dmk-muted uppercase block mb-2">Company</label>
        <input type="text" class="w-full bg-transparent font-mono text-sm text-dmk-text focus:outline-none placeholder:text-dmk-muted/50"/>
      </div>
      <div class="col-span-2 md:col-span-1 border-b border-dmk-muted/20 p-4">
        <label class="font-mono text-[10px] text-dmk-muted uppercase block mb-2">Role</label>
        <input type="text" class="w-full bg-transparent font-mono text-sm text-dmk-text focus:outline-none placeholder:text-dmk-muted/50"/>
      </div>
      <div class="col-span-4 border-b border-dmk-muted/20 p-4">
        <label class="font-mono text-[10px] text-dmk-muted uppercase block mb-2">Message</label>
        <textarea class="w-full bg-transparent font-mono text-sm text-dmk-text focus:outline-none resize-none placeholder:text-dmk-muted/50" rows="3"></textarea>
      </div>
      <div class="col-span-4 p-4 flex justify-between items-center">
        <div class="font-mono text-[10px] text-dmk-muted">Santiago, CL · contacto@datametrik.cl</div>
        <button type="submit" class="font-mono text-xs text-dmk-accent border border-dmk-accent px-4 py-2 hover:bg-dmk-accent hover:text-dmk-bg transition-colors">
          SUBMIT
        </button>
      </div>
    </form>

  </div>
</section>
