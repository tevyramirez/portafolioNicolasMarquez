---
import '../styles/global.css';
import '../styles/animations.css';
import '../styles/3d-minimal.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Dr. Nicolás Márquez Álvarez | PhD in Management · Portafolio Académico",
  description = "Portafolio académico del Dr. Nicolás Matías Márquez Álvarez, PhD in Management por la Universidad Adolfo Ibáñez."
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es-CL" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />

    <script is:inline>
      const savedTheme = localStorage.getItem("portfolio-theme-id") || "style-01";
      const savedColor = localStorage.getItem("portfolio-theme-color");
      document.documentElement.setAttribute("data-theme-id", savedTheme);
      if (savedColor) {
        document.documentElement.style.setProperty("--color-accent-base", savedColor);
      }
    </script>
  </head>
  <body class="min-h-screen bg-dmk-bg text-dmk-text">
    <slot />
    
    <script is:inline>
      // Scroll Reveal System
      (function() {
        const observerOptions = {
          root: null,
          rootMargin: '0px',
          threshold: 0.1
        };
        
        const revealObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              // Unobserve after revealing to keep the state
              revealObserver.unobserve(entry.target);
            }
          });
        }, observerOptions);
        
        // Observe all reveal elements
        document.addEventListener('DOMContentLoaded', () => {
          const revealElements = document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale');
          revealElements.forEach(el => revealObserver.observe(el));
        });
        
        // Immediate reveal for above-fold content
        document.addEventListener('DOMContentLoaded', () => {
          const immediateReveals = document.querySelectorAll('.reveal-immediate');
          immediateReveals.forEach(el => el.classList.add('visible'));
        });
      })();
    </script>
  </body>
</html>
