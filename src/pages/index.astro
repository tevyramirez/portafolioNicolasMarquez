---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="es-CL">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Nicolás Márquez Álvarez | PhD · Portafolio Académico</title>
    <meta name="description" content="Portafolio académico del Dr. Nicolás Márquez Álvarez, PhD in Management. Investigación en emprendimiento, innovación y sostenibilidad en América Latina." />
    <meta name="robots" content="noindex, nofollow" />
  </head>
  <body class="bg-[#FAFAFA] text-[#1A1A1A] min-h-screen font-sans flex flex-col items-center p-8 md:p-16">
    
    <div class="max-w-4xl w-full space-y-16">
      
      <!-- Cabecera institucional -->
      <div class="text-center space-y-6">
        <div class="font-sans text-xs text-[#5A5A5A] uppercase tracking-[0.2em]">
          PhD in Management · Universidad Adolfo Ibáñez
        </div>
        <h1 class="font-serif text-4xl md:text-5xl font-bold text-[#1A1A1A] tracking-tight">
          Nicolás Márquez Álvarez
        </h1>
        <p class="font-sans text-base text-[#5A5A5A] max-w-2xl mx-auto leading-relaxed">
          Entrepreneurship and innovation scholar. Research focuses on entrepreneurship, SME innovation, sustainability, and the implications of AI for entrepreneurial judgment and innovation governance in Latin America.
        </p>
        <div class="flex items-center justify-center gap-4 text-sm text-[#5A5A5A]">
          <span>nicolasmarquezalvarez@gmail.com</span>
          <span class="text-[#8B0000]">·</span>
          <span>(+56) 930610500</span>
          <span class="text-[#8B0000]">·</span>
          <span>Talca, Chile</span>
        </div>
      </div>

      <!-- Opción principal: Harvard Style -->
      <div class="space-y-6">
        <div class="text-center">
          <div class="font-sans text-xs text-[#8B0000] uppercase tracking-[0.2em] mb-2">Portafolio Académico</div>
          <h2 class="font-serif text-2xl font-semibold text-[#1A1A1A]">Estilo Harvard / Institucional</h2>
          <p class="font-sans text-sm text-[#5A5A5A] mt-2 max-w-lg mx-auto">
            Basado en datos reales del CV. Sobrio, académico, sin datos ficticios. Publicaciones con DOIs reales, posiciones académicas verificables, referencias de contacto.
          </p>
        </div>

        <a href="/estilo-harvard" class="group block border border-[#E5E5E5] bg-white rounded-sm overflow-hidden hover:border-[#8B0000] transition-all duration-300 shadow-sm hover:shadow-md">
          <div class="h-32 bg-[#F8F9FA] border-b border-[#E5E5E5] flex items-center justify-center">
            <div class="flex gap-2">
              <span class="w-5 h-5 rounded-full bg-[#8B0000]"></span>
              <span class="w-5 h-5 rounded-full bg-[#A52A2A]"></span>
              <span class="w-5 h-5 rounded-full bg-[#1A1A1A]"></span>
            </div>
          </div>
          <div class="p-6 flex items-center justify-between">
            <div>
              <h3 class="font-serif text-xl font-semibold text-[#1A1A1A] group-hover:text-[#8B0000] transition-colors">
                Ver portafolio completo
              </h3>
              <p class="font-sans text-sm text-[#5A5A5A] mt-1">
                Profile · Research · Teaching · Experience · Contact
              </p>
            </div>
            <span class="font-serif text-lg text-[#8B0000]">→</span>
          </div>
        </a>
      </div>

      <!-- Alternativas de exploración (compacto) -->
      <div class="space-y-6">
        <div class="flex items-center gap-4">
          <div class="h-px flex-1 bg-[#E5E5E5]"></div>
          <div class="font-sans text-xs text-[#5A5A5A] uppercase tracking-[0.2em]">
            Alternativas de diseño
          </div>
          <div class="h-px flex-1 bg-[#E5E5E5]"></div>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
          <a href="/estilo-observatory" class="block border border-[#E5E5E5] bg-white p-4 rounded-sm hover:border-[#00F0FF] transition-colors">
            <div class="font-serif text-sm font-semibold text-[#1A1A1A]">Experimental</div>
            <div class="font-sans text-xs text-[#5A5A5A] mt-1">3D · Inmersivo</div>
          </a>
          <a href="/estilo-atelier" class="block border border-[#E5E5E5] bg-white p-4 rounded-sm hover:border-[#6B2737] transition-colors">
            <div class="font-serif text-sm font-semibold text-[#1A1A1A]">Editorial</div>
            <div class="font-sans text-xs text-[#5A5A5A] mt-1">Revista · Lujo</div>
          </a>
          <a href="/estilo-swiss" class="block border border-[#E5E5E5] bg-white p-4 rounded-sm hover:border-[#FF3B30] transition-colors">
            <div class="font-serif text-sm font-semibold text-[#1A1A1A]">Brutalista</div>
            <div class="font-sans text-xs text-[#5A5A5A] mt-1">Grid · Datos</div>
          </a>
          <a href="/estilo-folio" class="block border border-[#E5E5E5] bg-white p-4 rounded-sm hover:border-[#2B6CB0] transition-colors">
            <div class="font-serif text-sm font-semibold text-[#1A1A1A]">Clásico</div>
            <div class="font-sans text-xs text-[#5A5A5A] mt-1">APA · Formal</div>
          </a>
        </div>
      </div>

      <!-- Footer -->
      <div class="text-center pt-8 border-t border-[#E5E5E5]">
        <p class="font-sans text-xs text-[#5A5A5A]">
          © 2026 Nicolás Matías Márquez Álvarez. PhD in Management, Universidad Adolfo Ibáñez.
        </p>
      </div>

    </div>

  </body>
</html>
