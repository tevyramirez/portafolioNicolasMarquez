---
import '../styles/global.css';
import '../styles/animations.css';
import '../styles/3d-minimal.css';
---

<!DOCTYPE html>
<html lang="es-CL">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Dr. Nicolás Márquez Álvarez · Vitrina de Estilos</title>
    <meta name="description" content="Vitrina de estilos visuales para el portafolio del Dr. Nicolás Márquez Álvarez, PhD UAI. 9 direcciones de diseño." />
    <meta name="robots" content="noindex, nofollow" />
  </head>
  <body class="bg-[#F5F5F5] text-[#1A1A1A] min-h-screen font-sans gradient-aurora">
    
    <div class="max-w-6xl mx-auto px-8 md:px-12 py-16 md:py-24 space-y-20">

      <!-- Header -->
      <div class="space-y-6 reveal stagger-1">
        <div class="font-sans text-xs text-[#8B0000] uppercase tracking-[0.25em] font-medium">
          Dr. Nicolás Matías Márquez Álvarez · PhD in Management · UAI
        </div>
        <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-bold text-[#1A1A1A] tracking-tight leading-tight text-gradient">
          Portafolio Académico
        </h1>
        <div class="h-px w-24 bg-[#8B0000] divider-animated"></div>
        <p class="font-sans text-base md:text-lg text-[#5A5A5A] max-w-2xl leading-relaxed">
          Nueve direcciones de diseño visual para el portafolio del Dr. Márquez. Datos reales extraídos de su CV académico.
        </p>
      </div>

      <!-- Sección 1: Arquitecturas Distintas -->
      <div class="space-y-8">
        <div class="flex items-center gap-6 reveal stagger-2">
          <h2 class="font-serif text-xl font-semibold text-[#1A1A1A]">Arquitecturas Distintas</h2>
          <div class="h-px flex-1 bg-[#E5E5E5]"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          
          <!-- Observatory -->
          <a href="/estilo-observatory" class="group block card-premium hover-lift overflow-hidden reveal stagger-1">
            <div class="h-32 bg-[#0A0A0F] flex items-center justify-center relative overflow-hidden">
              <div class="absolute inset-0 opacity-30">
                <div class="absolute w-1 h-1 rounded-full bg-[#00F0FF] particle" style="left: 15%; top: 30%; animation-delay: 0s;"></div>
                <div class="absolute w-1 h-1 rounded-full bg-[#00F0FF] particle" style="left: 40%; top: 60%; animation-delay: 1s;"></div>
                <div class="absolute w-1 h-1 rounded-full bg-[#00F0FF] particle" style="left: 70%; top: 35%; animation-delay: 2s;"></div>
                <div class="absolute w-1 h-1 rounded-full bg-[#00F0FF] particle" style="left: 85%; top: 55%; animation-delay: 0.5s;"></div>
                <div class="absolute w-1 h-1 rounded-full bg-[#00F0FF] particle" style="left: 25%; top: 75%; animation-delay: 1.5s;"></div>
                <div class="absolute w-1 h-1 rounded-full bg-[#00F0FF] particle" style="left: 55%; top: 15%; animation-delay: 2.5s;"></div>
              </div>
              <div class="relative z-10 text-center">
                <div class="font-mono text-xs text-white/40 uppercase tracking-wider mb-1">Experimental</div>
                <div class="font-serif text-xl text-white font-semibold group-hover:text-[#00F0FF] transition-colors duration-300">Observatory</div>
              </div>
            </div>
            <div class="p-5 space-y-2">
              <h3 class="font-serif text-lg font-semibold text-[#1A1A1A] group-hover:text-[#8B0000] transition-colors duration-300">The Observatory</h3>
              <p class="font-sans text-sm text-[#5A5A5A] leading-relaxed">Layout inmersivo con tipografía monospace. Partículas decorativas y composición asimétrica. Ideal para perfiles técnicos y de innovación.</p>
              <div class="flex items-center gap-2 pt-2">
                <span class="w-3 h-3 rounded-full bg-[#00F0FF]"></span>
                <span class="w-3 h-3 rounded-full bg-[#6B6B7B]"></span>
                <span class="font-sans text-xs text-[#5A5A5A]">Dark · Experimental · Inmersivo</span>
              </div>
            </div>
          </a>

          <!-- Atelier -->
          <a href="/estilo-atelier" class="group block card-premium hover-lift overflow-hidden reveal stagger-2">
            <div class="h-32 bg-[#F7F5F0] flex items-center justify-center relative paper-texture">
              <div class="text-center">
                <div class="font-serif text-xs text-[#C4A882] italic mb-2">Editorial Lore</div>
                <div class="font-serif text-3xl font-light text-[#6B2737] italic group-hover:scale-110 transition-transform duration-500 inline-block">N</div>
              </div>
            </div>
            <div class="p-5 space-y-2">
              <h3 class="font-serif text-lg font-semibold text-[#1A1A1A] group-hover:text-[#6B2737] transition-colors duration-300">L'Atelier · Editorial</h3>
              <p class="font-sans text-sm text-[#5A5A5A] leading-relaxed">Estilo revista con retrato grande, layout asimétrico y columnas angostas. Inspirado en el diseño editorial de lujo.</p>
              <div class="flex items-center gap-2 pt-2">
                <span class="w-3 h-3 rounded-full bg-[#6B2737]"></span>
                <span class="w-3 h-3 rounded-full bg-[#C4A882]"></span>
                <span class="font-sans text-xs text-[#5A5A5A]">Claro · Editorial · Burgoña</span>
              </div>
            </div>
          </a>

          <!-- Swiss Grid -->
          <a href="/estilo-swiss" class="group block card-premium hover-lift overflow-hidden reveal stagger-3">
            <div class="h-32 bg-[#FAFAFA] flex items-center justify-center border-b border-[#E5E5E5] relative overflow-hidden">
              <div class="absolute inset-0 opacity-10">
                <div class="absolute top-0 left-1/4 w-px h-full bg-[#1A1A1A]"></div>
                <div class="absolute top-0 left-1/2 w-px h-full bg-[#1A1A1A]"></div>
                <div class="absolute top-0 left-3/4 w-px h-full bg-[#1A1A1A]"></div>
              </div>
              <div class="text-center space-y-1 relative z-10">
                <div class="font-mono text-xs text-[#8A8A8A] uppercase tracking-wider">SWISS DATA</div>
                <div class="flex gap-1 justify-center">
                  <div class="w-12 h-0.5 bg-[#FF3B30] rounded group-hover:w-16 transition-all duration-300"></div>
                  <div class="w-8 h-0.5 bg-[#1A1A1A] rounded group-hover:w-12 transition-all duration-300"></div>
                </div>
              </div>
            </div>
            <div class="p-5 space-y-2">
              <h3 class="font-serif text-lg font-semibold text-[#1A1A1A] group-hover:text-[#FF3B30] transition-colors duration-300">The Swiss Grid</h3>
              <p class="font-sans text-sm text-[#5A5A5A] leading-relaxed">Tablas de datos monospace, grid estricto y tipografía funcional. Estilo brutalista suizo para perfiles analíticos.</p>
              <div class="flex items-center gap-2 pt-2">
                <span class="w-3 h-3 rounded-full bg-[#FF3B30]"></span>
                <span class="w-3 h-3 rounded-full bg-[#1A1A1A]"></span>
                <span class="font-sans text-xs text-[#5A5A5A]">Brutalista · Datos · Monospace</span>
              </div>
            </div>
          </a>

          <!-- Folio (Harvard-style) -->
          <a href="/estilo-folio" class="group block card-premium hover-lift overflow-hidden relative reveal stagger-4">
            <div class="absolute top-3 right-3 bg-[#8B0000] text-white font-sans text-xs px-3 py-1 rounded-sm badge-pulse z-10">Recomendado</div>
            <div class="h-32 bg-white flex items-center justify-center border-b border-[#E5E5E5] relative overflow-hidden">
              <div class="absolute inset-0 bg-gradient-to-br from-[#8B0000]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              <div class="flex items-center gap-4 relative z-10">
                <div class="w-12 h-16 bg-[#F8F9FA] border border-[#E5E5E5] flex items-center justify-center group-hover:shadow-md transition-shadow duration-300">
                  <span class="font-serif text-xl text-[#8B0000] group-hover:scale-110 transition-transform duration-300 inline-block">N</span>
                </div>
                <div class="text-left space-y-1">
                  <div class="w-24 h-1 bg-[#1A1A1A] rounded"></div>
                  <div class="w-16 h-1 bg-[#5A5A5A] rounded"></div>
                </div>
              </div>
            </div>
            <div class="p-5 space-y-2">
              <h3 class="font-serif text-lg font-semibold text-[#1A1A1A] group-hover:text-[#8B0000] transition-colors duration-300">The Folio · Harvard</h3>
              <p class="font-sans text-sm text-[#5A5A5A] leading-relaxed">Formato académico institucional con banner formal, bibliografía APA y diseño sobrio. El estándar universitario.</p>
              <div class="flex items-center gap-2 pt-2">
                <span class="w-3 h-3 rounded-full bg-[#8B0000]"></span>
                <span class="w-3 h-3 rounded-full bg-[#1A1A1A]"></span>
                <span class="font-sans text-xs text-[#5A5A5A]">Académico · APA · Harvard</span>
              </div>
            </div>
          </a>

        </div>
      </div>

      <!-- Sección 2: Variaciones de Paleta -->
      <div class="space-y-8">
        <div class="flex items-center gap-6 reveal stagger-3">
          <h2 class="font-serif text-xl font-semibold text-[#1A1A1A]">Variaciones de Paleta</h2>
          <div class="h-px flex-1 bg-[#E5E5E5]"></div>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
          
          <a href="/estilo-datametrik-dark" class="group block card-premium hover-lift overflow-hidden reveal stagger-1">
            <div class="h-2 bg-[#00FF85] w-full"></div>
            <div class="h-14 bg-[#121212] flex items-center justify-center relative overflow-hidden">
              <div class="absolute inset-0 bg-gradient-to-r from-[#00FF85]/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              <div class="font-mono text-xs text-white/60 group-hover:text-[#00FF85] transition-colors duration-300">Dark</div>
            </div>
            <div class="p-3">
              <h3 class="font-serif text-sm font-semibold text-[#1A1A1A] group-hover:text-[#00FF85] transition-colors duration-300">Obsidian</h3>
              <p class="font-sans text-xs text-[#5A5A5A]">Fondo oscuro · Cyber Green</p>
            </div>
          </a>

          <a href="/estilo-bravo-ortega" class="group block card-premium hover-lift overflow-hidden reveal stagger-2">
            <div class="h-2 bg-[#C75B39] w-full"></div>
            <div class="h-14 bg-[#FAFAF5] flex items-center justify-center relative overflow-hidden">
              <div class="absolute inset-0 bg-gradient-to-r from-[#C75B39]/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              <div class="font-sans text-xs text-[#2D1B11]/60 group-hover:text-[#C75B39] transition-colors duration-300">Otoñal</div>
            </div>
            <div class="p-3">
              <h3 class="font-serif text-sm font-semibold text-[#1A1A1A] group-hover:text-[#C75B39] transition-colors duration-300">Bravo-Ortega</h3>
              <p class="font-sans text-xs text-[#5A5A5A]">Tonos cálidos · Naranja</p>
            </div>
          </a>

          <a href="/estilo-symmes" class="group block card-premium hover-lift overflow-hidden reveal stagger-3">
            <div class="h-2 bg-[#CC3333] w-full"></div>
            <div class="h-14 bg-white flex items-center justify-center border-b border-[#E5E5E5] relative overflow-hidden">
              <div class="absolute inset-0 bg-gradient-to-r from-[#CC3333]/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              <div class="font-sans text-xs text-[#0A0A0A]/60 group-hover:text-[#CC3333] transition-colors duration-300">Alto contraste</div>
            </div>
            <div class="p-3">
              <h3 class="font-serif text-sm font-semibold text-[#1A1A1A] group-hover:text-[#CC3333] transition-colors duration-300">Symmes</h3>
              <p class="font-sans text-xs text-[#5A5A5A]">Blanco y negro · Rojo</p>
            </div>
          </a>

          <a href="/estilo-madrid" class="group block card-premium hover-lift overflow-hidden reveal stagger-4">
            <div class="h-2 bg-[#003D6B] w-full"></div>
            <div class="h-14 bg-white flex items-center justify-center border-b border-[#E5E5E5] relative overflow-hidden">
              <div class="absolute inset-0 bg-gradient-to-r from-[#003D6B]/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              <div class="font-sans text-xs text-[#1A2A3A]/60 group-hover:text-[#003D6B] transition-colors duration-300">Científico UAI</div>
            </div>
            <div class="p-3">
              <h3 class="font-serif text-sm font-semibold text-[#1A1A1A] group-hover:text-[#003D6B] transition-colors duration-300">Madrid</h3>
              <p class="font-sans text-xs text-[#5A5A5A]">Institucional · Azul</p>
            </div>
          </a>

          <a href="/estilo-duran" class="group block card-premium hover-lift overflow-hidden reveal stagger-5">
            <div class="h-2 bg-[#1A365D] w-full"></div>
            <div class="h-14 bg-[#F8F9FA] flex items-center justify-center relative overflow-hidden">
              <div class="absolute inset-0 bg-gradient-to-r from-[#1A365D]/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              <div class="font-sans text-xs text-[#1C1E21]/60 group-hover:text-[#1A365D] transition-colors duration-300">Ejecutivo</div>
            </div>
            <div class="p-3">
              <h3 class="font-serif text-sm font-semibold text-[#1A1A1A] group-hover:text-[#1A365D] transition-colors duration-300">Durán</h3>
              <p class="font-sans text-xs text-[#5A5A5A]">C-Suite · Gris asfalto</p>
            </div>
          </a>

        </div>
      </div>

      <!-- Footer -->
      <div class="text-center pt-8 border-t border-[#E5E5E5] reveal stagger-5">
        <p class="font-sans text-sm text-[#5A5A5A] footer-link inline-block">
          Todos los datos provienen del CV real del Dr. Nicolás Matías Márquez Álvarez.
        </p>
      </div>

    </div>

    <script is:inline>
      // Scroll Reveal System
      (function() {
        const observerOptions = {
          root: null,
          rootMargin: '0px',
          threshold: 0.1
        };
        
        const revealObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              revealObserver.unobserve(entry.target);
            }
          });
        }, observerOptions);
        
        document.addEventListener('DOMContentLoaded', () => {
          const revealElements = document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale');
          revealElements.forEach(el => revealObserver.observe(el));
        });
      })();
    </script>

  </body>
</html>
